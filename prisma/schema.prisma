generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Transaction {
  id        Int      @id @default(autoincrement())
  type      String   // "income" or "expense"
  amount    Float
  category  String
  date      String   // ISO date string
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
